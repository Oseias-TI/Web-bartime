generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                   String             @id @default(uuid())
  cnpj                 String             @unique
  name                 String
  slug                 String             @unique
  logoUrl              String?
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  subscriptionStatus   SubscriptionStatus @default(TRIAL)
  currentPeriodEnd     DateTime?
  trialEndsAt          DateTime?
  createdAt            DateTime           @default(now())
  appointments         Appointment[]
  auditLogs            AuditLog[]
  businessHours        BusinessHour[]
  clients              Client[]
  commissions          Commission[]
  professionals        Professional[]
  services             Service[]
  transactions         Transaction[]

  @@map("tenants")
}

model BusinessHour {
  id         String  @id @default(uuid())
  tenantId   String
  dayOfWeek  Int
  open       Boolean @default(true)
  openTime   String?
  closeTime  String?
  openTime2  String?
  closeTime2 String?
  tenant     Tenant  @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, dayOfWeek])
  @@map("business_hours")
}

model Client {
  id             String        @id @default(uuid())
  tenantId       String
  name           String
  phone          String
  email          String?
  password       String?
  preferences    String?
  loyaltyPoints  Int           @default(0)
  consentedAt    DateTime?
  consentVersion String?
  consentIp      String?
  createdAt      DateTime      @default(now())
  appointments   Appointment[]
  consentLogs    ConsentLog[]
  passwordResetTokens ClientPasswordResetToken[]
  tenant         Tenant        @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, phone])
  @@map("clients")
}

model Service {
  id           String        @id @default(uuid())
  tenantId     String
  name         String
  price        Decimal       @db.Decimal(10, 2)
  durationMin  Int
  active       Boolean       @default(true)
  appointments Appointment[]
  tenant       Tenant        @relation(fields: [tenantId], references: [id])

  @@map("services")
}

model Appointment {
  id             String                @id @default(uuid())
  tenantId       String
  clientId       String
  professionalId String
  serviceId      String
  startTime      DateTime
  endTime        DateTime
  status         AppointmentStatus     @default(PENDING)
  paymentMethod  String?
  googleEventId  String?
  reminders      AppointmentReminder[]
  client         Client                @relation(fields: [clientId], references: [id])
  professional   Professional          @relation(fields: [professionalId], references: [id])
  service        Service               @relation(fields: [serviceId], references: [id])
  tenant         Tenant                @relation(fields: [tenantId], references: [id])
  commission     Commission?
  transaction    Transaction?

  @@map("appointments")
}

model Commission {
  id             String           @id @default(uuid())
  tenantId       String
  appointmentId  String           @unique
  professionalId String
  amount         Decimal          @db.Decimal(10, 2)
  status         CommissionStatus @default(PENDING)
  createdAt      DateTime         @default(now())
  appointment    Appointment      @relation(fields: [appointmentId], references: [id])
  professional   Professional     @relation(fields: [professionalId], references: [id])
  tenant         Tenant           @relation(fields: [tenantId], references: [id])

  @@map("commissions")
}

model Transaction {
  id            String          @id @default(uuid())
  tenantId      String
  appointmentId String?         @unique
  type          TransactionType
  category      String
  paymentMethod String?
  amount        Decimal         @db.Decimal(10, 2)
  description   String?
  createdAt     DateTime        @default(now())
  appointment   Appointment?    @relation(fields: [appointmentId], references: [id])
  tenant        Tenant          @relation(fields: [tenantId], references: [id])

  @@map("transactions")
}

model RefreshToken {
  id             String       @id @default(uuid())
  token          String       @unique
  professionalId String
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  professional   Professional @relation(fields: [professionalId], references: [id])

  @@map("refresh_tokens")
}

model PasswordResetToken {
  id             String       @id @default(uuid())
  token          String       @unique
  professionalId String
  expiresAt      DateTime
  used           Boolean      @default(false)
  createdAt      DateTime     @default(now())
  professional   Professional @relation(fields: [professionalId], references: [id])

  @@map("password_reset_tokens")
}

model ClientPasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  clientId  String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id])

  @@map("client_password_reset_tokens")
}

model Professional {
  id                      String                   @id @default(uuid())
  tenantId                String
  name                    String
  email                   String
  password                String
  avatarUrl               String?
  commissionRate          Decimal                  @default(50.0) @db.Decimal(5, 2)
  role                    Role                     @default(BARBER)
  active                  Boolean                  @default(true)
  emailVerified           Boolean                  @default(false)
  consentedAt             DateTime?
  consentVersion          String?
  consentIp               String?
  appointments            Appointment[]
  commissions             Commission[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  tenant                  Tenant                   @relation(fields: [tenantId], references: [id])
  refreshTokens           RefreshToken[]

  @@unique([tenantId, email])
  @@map("professionals")
}

model EmailVerificationToken {
  id             String       @id @default(uuid())
  token          String       @unique
  professionalId String
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  professional   Professional @relation(fields: [professionalId], references: [id])

  @@map("email_verification_tokens")
}

model AuditLog {
  id             String   @id @default(uuid())
  tenantId       String?
  professionalId String?
  action         String
  entity         String
  entityId       String?
  metadata       Json?
  ipAddress      String?
  createdAt      DateTime @default(now())
  tenant         Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([action])
  @@map("audit_logs")
}

model AppointmentReminder {
  id            String       @id @default(uuid())
  appointmentId String
  type          ReminderType
  sentAt        DateTime     @default(now())
  appointment   Appointment  @relation(fields: [appointmentId], references: [id])

  @@unique([appointmentId, type])
  @@map("appointment_reminders")
}

model ConsentLog {
  id             String        @id @default(uuid())
  clientId       String?
  professionalId String?
  action         ConsentAction
  consentVersion String
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime      @default(now())
  client         Client?       @relation(fields: [clientId], references: [id])

  @@index([clientId, createdAt])
  @@index([professionalId, createdAt])
  @@map("consent_logs")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  BARBER
  RECEPTIONIST
}

enum AppointmentStatus {
  PENDING
  COMPLETED
  CANCELED
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum CommissionStatus {
  PENDING
  PAID
  CANCELED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum ReminderType {
  EMAIL_24H
  EMAIL_1H
}

enum ConsentAction {
  GRANTED
  REVOKED
  UPDATED
}
