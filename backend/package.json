{
    "name": "bartime-api",
    "version": "1.0.0",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "build": "prisma generate && tsc",
        "start": "node dist/server.js",
        "db:push": "prisma db push",
        "db:migrate": "prisma migrate dev",
        "db:deploy": "prisma migrate deploy",
        "db:studio": "prisma studio",
        "db:generate": "prisma generate",
        "docker:up": "docker compose up -d --build",
        "docker:down": "docker compose down",
        "docker:logs": "docker compose logs -f api",
        "docker:reset": "docker compose down -v && docker compose up -d --build",
        "stripe:listen": "stripe listen --forward-to localhost:3333/webhooks/stripe",
        "test": "jest",
        "test:e2e": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.ts --testPathPatterns=tests/integration",
        "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.ts --testPathPatterns=tests/unit",
        "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.0.0",
        "@prisma/client": "^5.0.0",
        "bcryptjs": "^2.4.3",
        "cloudflare": "^6.4.0",
        "cors": "^2.8.5",
        "dotenv": "^16.0.0",
        "exceljs": "^3.4.0",
        "express": "^4.18.0",
        "express-rate-limit": "^8.5.1",
        "googleapis": "^173.0.0",
        "helmet": "^7.0.0",
        "jsonwebtoken": "^9.0.3",
        "multer": "^1.4.5-lts.1",
        "multer-s3": "^3.0.0",
        "node-cron": "^4.2.1",
        "nodemailer": "^8.0.10",
        "pdfkit": "^0.18.0",
        "prom-client": "^15.1.3",
        "redis": "^6.0.0",
        "stripe": "^14.0.0",
        "uuid": "^9.0.1",
        "winston": "^3.19.0",
        "winston-elasticsearch": "^0.11.0",
        "zod": "^3.22.0"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/express-rate-limit": "^5.1.3",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/multer": "^1.4.11",
        "@types/multer-s3": "^3.0.3",
        "@types/node-cron": "^3.0.11",
        "@types/nodemailer": "^6.4.14",
        "@types/pdfkit": "^0.17.6",
        "@types/supertest": "^7.2.0",
        "@types/uuid": "^10.0.0",
        "jest": "^30.4.2",
        "prisma": "^5.0.0",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.11",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.0.0"
    },
    "prisma": {
        "seed": "ts-node-dev --transpile-only prisma/seed.ts"
    }
}
